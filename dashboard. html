<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>File Manager | High Stars Aimers</title>
  
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://www.gstatic.com/firebasejs/10.11.0/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.11.0/firebase-auth-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.11.0/firebase-storage-compat.js"></script>

  <style>
    :root {
      --primary: #2563eb;
      --danger: #dc2626;
      --bg: #f8fafc;
      --card-bg: #ffffff;
      --text-main: #1e293b;
      --text-muted: #64748b;
      --border: #e2e8f0;
      --shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
      --radius: 12px;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text-main); padding-bottom: 50px; }

    .header {
      background: white;
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid var(--border);
      position: sticky; top: 0; z-index: 100;
    }

    .container { max-width: 800px; margin: 2rem auto; padding: 0 1rem; }

    .stats-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.5rem;
    }

    .btn {
      padding: 0.6rem 1rem;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
      border: none;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      transition: 0.2s;
    }

    .btn-refresh { background: var(--primary); color: white; }
    .btn-back { background: transparent; color: var(--text-muted); text-decoration: none; font-size: 0.9rem; }

    .file-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1rem 1.25rem;
      margin-bottom: 0.75rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: var(--shadow);
      animation: fadeIn 0.3s ease;
    }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    .file-info { display: flex; align-items: center; gap: 1rem; }
    .file-icon { width: 40px; height: 40px; background: #eff6ff; color: var(--primary); border-radius: 8px; display: flex; align-items: center; justify-content: center; }

    .file-name { font-weight: 500; font-size: 0.95rem; word-break: break-all; }
    .file-path { font-size: 0.75rem; color: var(--text-muted); }

    .btn-delete {
      background: #fef2f2;
      color: var(--danger);
      width: 35px;
      height: 35px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      border: none;
      cursor: pointer;
    }
    .btn-delete:hover { background: var(--danger); color: white; }

    .loading-spinner { text-align: center; padding: 3rem; color: var(--text-muted); }
    
    /* Responsive */
    @media (max-width: 480px) {
      .header { padding: 1rem; }
      .file-info { gap: 0.75rem; }
    }
  </style>
</head>
<body>

<header class="header">
  <a href="dashboard.html" class="btn-back"><i class="fas fa-arrow-left"></i> Dashboard</a>
  <h2 style="font-size: 1.1rem;">Storage Manager</h2>
  <div style="width: 80px;"></div> </header>

<div class="container">
  <div class="stats-bar">
    <div>
      <h3 id="folderTitle">Files in "Form 1/"</h3>
      <p id="fileCount" style="font-size: 0.85rem; color: var(--text-muted);">Scanning storage...</p>
    </div>
    <button class="btn btn-refresh" onclick="listFiles()">
      <i class="fas fa-sync-alt"></i> Refresh
    </button>
  </div>

  <div id="fileList">
    <div class="loading-spinner">
      <i class="fas fa-circle-notch fa-spin fa-2x"></i>
      <p style="margin-top: 1rem;">Accessing Firebase Storage...</p>
    </div>
  </div>
</div>

<script>
  // 1. REPLACE WITH YOUR ACTUAL FIREBASE CONFIG
  const firebaseConfig = {
    apiKey: "YOUR_API_KEY",
    authDomain: "high-stars-aimers-5972f.firebaseapp.com",
    projectId: "high-stars-aimers-5972f",
    storageBucket: "high-stars-aimers-5972f.firebasestorage.app",
    messagingSenderId: "YOUR_ID",
    appId: "YOUR_APP_ID"
  };

  // Initialize Firebase
  if (!firebase.apps.length) {
    firebase.initializeApp(firebaseConfig);
  }

  const storage = firebase.storage();
  const fileListElement = document.getElementById('fileList');
  const fileCountElement = document.getElementById('fileCount');

  // Change this to match the folder you want to manage
  const targetFolder = 'Form 1/'; 

  async function listFiles() {
    fileListElement.innerHTML = `
      <div class="loading-spinner">
        <i class="fas fa-circle-notch fa-spin fa-2x"></i>
        <p style="margin-top: 1rem;">Updating list...</p>
      </div>`;

    const listRef = storage.ref(targetFolder);

    try {
      const res = await listRef.listAll();
      fileListElement.innerHTML = '';
      fileCountElement.innerText = `${res.items.length} files found`;

      if (res.items.length === 0) {
        fileListElement.innerHTML = `
          <div style="text-align:center; padding: 3rem; color: var(--text-muted);">
            <i class="fas fa-folder-open fa-3x" style="margin-bottom:1rem; opacity:0.3;"></i>
            <p>This folder is empty.</p>
          </div>`;
        return;
      }

      res.items.forEach((itemRef) => {
        const card = document.createElement('div');
        card.className = 'file-card';
        
        card.innerHTML = `
          <div class="file-info">
            <div class="file-icon"><i class="fas fa-file-alt"></i></div>
            <div>
              <div class="file-name">${itemRef.name}</div>
              <div class="file-path">${targetFolder}</div>
            </div>
          </div>
          <button class="btn-delete" onclick="deleteFile('${itemRef.fullPath}', '${itemRef.name}')" title="Delete File">
            <i class="fas fa-trash-alt"></i>
          </button>
        `;
        fileListElement.appendChild(card);
      });
    } catch (error) {
      console.error(error);
      fileListElement.innerHTML = `<p style="color:red; text-align:center;">Error: ${error.message}. <br> Make sure you are logged in and Rules are set to public/user.</p>`;
    }
  }

  async function deleteFile(fullPath, fileName) {
    if (confirm(`Are you sure you want to delete "${fileName}"? This cannot be undone.`)) {
      const fileRef = storage.ref(fullPath);
      try {
        await fileRef.delete();
        // Success: Refresh the list
        listFiles(); 
      } catch (error) {
        alert("Failed to delete: " + error.message);
      }
    }
  }

  // Check Auth State (Optional but recommended)
  firebase.auth().onAuthStateChanged((user) => {
    if (user) {
      listFiles();
    } else {
      fileListElement.innerHTML = '<p style="text-align:center; padding:2rem;">Please log in to manage files.</p>';
    }
  });

</script>

</body>
</html>
